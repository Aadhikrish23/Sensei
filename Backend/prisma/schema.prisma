// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url= env("DATABASE_URL")
}

model User{
  id String   @id @default(uuid())
  email String @unique
  password String
  isEmailVerified Boolean @default(false)

  refreshToken String? @unique
  refreshExpires DateTime?

  verificationToken    String? @unique
  verificationExpires  DateTime?

  createdAt DateTime @default(now())
  updatedAt  DateTime @updatedAt

  resumes Resume[]
jobDescriptions JobDescription[]
interviewSessions InterviewSession[]
resumeMatches ResumeJDMatch[]

}

model Resume {
  id String @id @default(uuid())

  userId String
  title String
  filePath String

  extractedText String @db.Text
  parsedData Json?   // future structured extraction

  roleCategory  String?
  topicMatrix Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  interviewSessions InterviewSession[]
resumeMatches ResumeJDMatch[]
}

model JobDescription{

id String @id @default(uuid())
userId String
title String
rawText String @db.Text
parsedData Json?
roleCategory  String?
topicMatrix Json?

createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields:[userId],references:[id], onDelete:Cascade)
  @@index([userId])
  interviewSessions InterviewSession[]
resumeMatches ResumeJDMatch[]
}

enum SessionDifficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  ADAPTIVE
}

model InterviewSession {
  id             String   @id @default(uuid())

  userId         String
  resumeId       String
  jdId           String

  roleCategory   String
  
  difficulty     String

  totalQuestions Int      @default(0)

  skillGraph     Json?

  decision       String?

  completed      Boolean  @default(false)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  resume         Resume          @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  jobDescription JobDescription  @relation(fields: [jdId], references: [id], onDelete: Cascade)

  sessionSummary SessionSummary?
}

model SessionSummary {
  id String @id @default(uuid())

  sessionId String @unique

  // Core Category Averages (0–10 scale)
  technicalAvg Float
  depthAvg Float
  communicationAvg Float
  codingAvg Float
  relevanceAvg Float

  // Intelligence Metrics
  topicCoverageScore Float
  consistencyScore Float
  confidenceScore Float

  // Weighted Overall Score (0–100)
  overallScore Float

  // Meta Intelligence
  strongSkillTags Json?
  weakSkillTags Json?

  // Question Distribution Insight
  theoryQuestionCount Int
  codingQuestionCount Int

  createdAt DateTime @default(now())

  session InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([overallScore])
}

model ResumeJDMatch {
  id String @id @default(uuid())

  userId String
  resumeId String
  jdId String

  matchPercentage Float

  // Structured Skill Intelligence
  strongSkills Json?
  missingSkills Json?
  partiallyMatchedSkills Json?

  // AI Suggestions
  improvementSuggestions Json?

  // Intelligence Metadata
  resumeVersionHash String
  jdVersionHash String

  analyzedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  resume Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  jobDescription JobDescription @relation(fields: [jdId], references: [id], onDelete: Cascade)

  @@unique([resumeId, jdId])
  @@index([userId])
  @@index([resumeVersionHash])
@@index([jdVersionHash])
}